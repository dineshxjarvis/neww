# Vercel Environment Variables
# MySQL (Aiven)
SQL_HOST=your-mysql-host.aivencloud.com
SQL_USER=avnadmin
SQL_PASS=your-password-here
SQL_DB=defaultdb
SQL_PORT=15607

# Redis (Upstash)
REDIS_BASE_URL=https://your-redis-url.upstash.io
REDIS_TOKEN=your-token-here
REDIS_URL=redis://default:your-token-here@your-redis-host.upstash.io:6379

# MongoDB (Atlas)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
